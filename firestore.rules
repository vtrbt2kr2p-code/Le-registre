rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Un utilisateur ne peut lire/écrire QUE ses propres données.
    // Toute l'app est structurée sous utilisateurs/{uid} précisément pour
    // que cette unique règle protège tout : entreprise, devis, factures,
    // clients (voir app.js, fonctions pushToCloud/pullFromCloud). Même
    // l'auteur de l'app n'a AUCUN accès ici — il n'existe aucune règle
    // "admin" qui donnerait accès aux documents privés (voir le tableau de
    // bord admin, section "statistiques_globales" ci-dessous, qui ne lit
    // que des compteurs agrégés séparés, jamais ces documents).
    match /utilisateurs/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Compteurs agrégés et anonymes pour le tableau de bord admin : jamais
    // de contenu de devis/facture ici, uniquement des nombres. Écrits
    // uniquement par les Cloud Functions (Admin SDK, qui contourne ces
    // règles), lus uniquement par un compte dont le jeton porte le custom
    // claim "admin" (voir functions/index.js, fonctions grantAdmin et
    // getAdminStats).
    match /statistiques_globales/{document=**} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if false; // uniquement via Cloud Functions (Admin SDK)
    }

    // Tout le reste est refusé par défaut.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
