rules_version = '2';

// Ces règles garantissent qu'un utilisateur connecté ne peut lire et écrire
// QUE ses propres données (celles stockées sous son propre identifiant
// utilisateur), jamais celles d'un autre utilisateur.
//
// À appliquer dans la console Firebase : Firestore Database > Règles > coller
// ce contenu > Publier. (Ou via `firebase deploy --only firestore:rules`.)
service cloud.firestore {
  match /databases/{database}/documents {
    match /utilisateurs/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
