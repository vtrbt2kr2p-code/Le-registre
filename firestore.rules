rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Un utilisateur ne peut lire/écrire QUE ses propres données.
    // Toute l'app est structurée sous users/{uid}/... précisément pour
    // que cette unique règle protège tout : entreprise, devis, factures,
    // clients. Même l'auteur de l'app (Mike Pelé) n'a AUCUN accès ici —
    // il n'existe aucune règle "admin" qui donnerait accès aux documents
    // privés (voir le tableau de bord admin, module 5, qui ne lit que
    // des compteurs agrégés séparés, jamais ces documents).
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Compteurs agrégés et anonymes pour le dashboard admin (module 5) :
    // en lecture seule pour tout le monde n'est PAS souhaité — seule une
    // Cloud Function avec droits admin (server-side) doit écrire ici, et
    // seul un compte marqué "admin" via Custom Claims doit pouvoir lire.
    match /statistiques_globales/{document=**} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if false; // uniquement via Cloud Functions (Admin SDK)
    }

    // Tout le reste est refusé par défaut.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
